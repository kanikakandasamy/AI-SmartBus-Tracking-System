// Get Route By ID
exports.getRouteById = (req, res) => {

    const { id } = req.params;

    res.status(200).json({
        success: true,
        message: "Route retrieved successfully.",
        data: {
            id: id,
            routeName: "Route A",
            startPoint: "College Campus",
            endPoint: "Central Bus Stand",
            totalStops: 6
        }
    });

};

// Add New Route
exports.addRoute = (req, res) => {

    const { routeName, startPoint, endPoint } = req.body;

    res.status(201).json({
        success: true,
        message: "Route added successfully.",
        data: {
            routeName,
            startPoint,
            endPoint
        }
    });

};

// Update Route
exports.updateRoute = (req, res) => {

    const { id } = req.params;

    res.status(200).json({
        success: true,
        message: `Route with ID ${id} updated successfully.`
    });

};

// Delete Route
exports.deleteRoute = (req, res) => {

    const { id } = req.params;

    res.status(200).json({
        success: true,
        message: `Route with ID ${id} deleted successfully.`
    });

};

